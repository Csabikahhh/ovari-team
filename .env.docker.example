# Marveen — Docker configuration. Copy to `.env.docker` and fill in.
#   cp .env.docker.example .env.docker
# docker-compose.yml reads this via `env_file`. Do NOT commit your real one.

# ── Identity ───────────────────────────────────────────────────────────────
OWNER_NAME=Your Name
BOT_NAME=Marveen
# MAIN_AGENT_ID=marveen        # auto-derived from BOT_NAME if left unset

# ── Claude authentication (REQUIRED — set exactly ONE) ───────────────────────
# Cannot be created inside the container (no browser). Obtain out-of-band:
#   Pro/Max:  on a machine WITH a browser run `claude setup-token`, paste here.
CLAUDE_CODE_OAUTH_TOKEN=
#   OR Anthropic Console (pay-as-you-go) API key — do NOT set both:
# ANTHROPIC_API_KEY=

# ── Channel ──────────────────────────────────────────────────────────────────
CHANNEL_PROVIDER=telegram

# -- Telegram (default) -- token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram chat id. Leave 0 until paired; the bot only replies to
# allow-listed chats. After you pair once, it persists in the marveen-claude
# volume and is auto-recovered on restart (so you can leave this 0).
ALLOWED_CHAT_ID=0

# -- Slack (only if CHANNEL_PROVIDER=slack) --
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL_ID=C0123ABCDE

# ── Dashboard ────────────────────────────────────────────────────────────────
# The container binds 0.0.0.0:3420 and publishes it. Because that is reachable
# from your network, set a long random bearer token here.
DASHBOARD_TOKEN=change-me-to-a-long-random-string
# WEB_PORT=3420
# DASHBOARD_PUBLIC_URL=https://marveen.example.com

# ── Optional ─────────────────────────────────────────────────────────────────
# HEARTBEAT_CALENDAR_ID=you@example.com
# GOOGLE_API_KEY=
# OLLAMA_URL is wired to the sidecar in docker-compose.yml — override only if
# you run Ollama elsewhere, e.g. OLLAMA_URL=http://host.docker.internal:11434
